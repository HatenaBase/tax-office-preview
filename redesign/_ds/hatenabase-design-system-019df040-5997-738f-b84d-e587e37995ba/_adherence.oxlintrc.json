{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "case-study-v2/**",
              "flyer-deck/**",
              "slides/**",
              "ui_kits/corporate-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Zen Kaku Gothic New))/i]",
        "message": "Font not provided by the design system. Available: Zen Kaku Gothic New."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent",
      "--color-accent-line",
      "--color-accent-soft",
      "--color-bg",
      "--color-bg-sub",
      "--color-bg-sub-2",
      "--color-border",
      "--color-border-strong",
      "--color-primary",
      "--color-primary-700",
      "--color-primary-900",
      "--color-text",
      "--color-text-mute",
      "--container-max",
      "--container-pad",
      "--duration-1",
      "--duration-2",
      "--ease-out",
      "--font-family",
      "--font-weight-bold",
      "--font-weight-medium",
      "--font-weight-regular",
      "--freee",
      "--freee-dark",
      "--freee-deep",
      "--ink",
      "--ink-soft",
      "--line-height-base",
      "--line-height-tight",
      "--muted",
      "--paper",
      "--paper-2",
      "--pink",
      "--print-body",
      "--print-catch",
      "--print-sub",
      "--radius-lg",
      "--radius-md",
      "--radius-sm",
      "--saas-bakuraku",
      "--saas-freee",
      "--saas-kanjo",
      "--saas-kintone",
